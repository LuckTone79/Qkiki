// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  USER
  SUPPORT_VIEWER
  ADMIN
  SUPER_ADMIN
}

enum UserAccountStatus {
  ACTIVE
  SUSPENDED
}

enum CouponType {
  MONTHLY_FREE_30D
  MONTHLY_FREE_30D_DAILY_50
  LIFETIME_FREE
  LIFETIME_FREE_DAILY_50
  WEEKLY_CREDIT
  // Credit-only coupons (current system). 7-day / 30-day / lifetime grants of
  // either a fixed credit amount or unlimited credits for the period.
  CREDIT_7D
  CREDIT_30D
  CREDIT_LIFETIME
  UNLIMITED_7D
  UNLIMITED_30D
  UNLIMITED_LIFETIME
}

enum CouponRedemptionResult {
  APPLIED
  ALREADY_LIFETIME
  INACTIVE
  USED
}

enum SubscriptionEventType {
  COUPON_REDEMPTION
  MANUAL_GRANT
}

enum SubscriptionType {
  MONTHLY_FREE_30D
  LIFETIME_FREE
  WEEKLY_CREDIT_7D
  MANUAL
}

enum AttachmentKind {
  TEXT
  IMAGE
  PDF
}

enum PlanType {
  FREE
  STARTER
  PRO
  TEAM
}

enum BillingType {
  NONE
  MONTHLY
  YEARLY
  CREDIT
}

enum FeedbackCategory {
  BUG
  FEATURE
  IMPROVEMENT
  QUESTION
  OTHER
}

enum FeedbackStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum ProjectItemKind {
  SESSION
  RESULT
}

enum AdminAuditAction {
  ADMIN_LOGIN
  ADMIN_LOGOUT
  ADMIN_MFA_SUCCESS
  ADMIN_MFA_FAILURE
  USER_DETAIL_VIEW
  CONTENT_RAW_VIEW
  COUPON_CREATE
  COUPON_DEACTIVATE
  SUBSCRIPTION_MANUAL_GRANT
  PROVIDER_KEY_UPDATE
  PROVIDER_MODEL_UPDATE
  USER_SUSPEND
  USER_UNSUSPEND
  SYSTEM_SETTING_CHANGE
  FEEDBACK_VIEW
  FEEDBACK_STATUS_CHANGE
  FEEDBACK_REPLY
}

model User {
  id             String            @id @default(cuid())
  email          String            @unique
  name           String?
  passwordHash   String
  role           UserRole          @default(USER)
  status         UserAccountStatus @default(ACTIVE)
  planType       PlanType          @default(FREE)
  billingType    BillingType       @default(NONE)
  trialStartedAt DateTime?
  trialEndsAt    DateTime?
  isTrialUsed    Boolean           @default(false)
  lastActiveAt   DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  accounts                AuthAccount[]
  authSessions            AuthSession[]
  adminSessions           AdminSession[]          @relation("AdminSessions")
  adminAuditLogs          AdminAuditLog[]         @relation("AdminAuditBy")
  adminContentAccessLogs  AdminContentAccessLog[] @relation("AdminContentAccessBy")
  viewedByAdminAccessLogs AdminContentAccessLog[] @relation("AdminContentAccessViewed")
  createdCoupons          Coupon[]                @relation("CouponCreatedBy")
  redeemedCoupons         Coupon[]                @relation("CouponRedeemedBy")
  couponRedemptions       CouponRedemption[]
  subscription            UserSubscription?
  subscriptionLedger      SubscriptionLedger[]    @relation("SubscriptionLedgerUser")
  grantedSubscriptions    SubscriptionLedger[]    @relation("SubscriptionGrantedByAdmin")
  adminProviderConfigs    AdminProviderConfig[]   @relation("AdminProviderUpdatedBy")
  adminSystemSettings     AdminSystemSetting[]    @relation("SystemSettingUpdatedBy")
  projects                Project[]
  sessions                WorkbenchSession[]
  executionRuns           ExecutionRun[]
  aiRequests              AiRequest[]
  presets                 Preset[]
  attachments             SessionAttachment[]
  trialAccess             TrialAccess?
  usageLimits             UsageLimit[]
  usageReservations       UsageReservation[]
  usageLogs               UsageLog[]
  creditWallet            CreditWallet?
  sharedLinks             SharedLink[]
  feedbackPosts           FeedbackPost[]          @relation("FeedbackAuthor")
  feedbackComments        FeedbackComment[]       @relation("FeedbackCommentAuthor")
  feedbackAttachments     FeedbackAttachment[]    @relation("FeedbackAttachmentOwner")
  projectItems            ProjectItem[]
}

model AuthAccount {
  id                String   @id @default(cuid())
  userId            String
  provider          String
  providerAccountId String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model AuthSession {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Project {
  id            String   @id @default(cuid())
  userId        String
  name          String
  description   String?
  sharedContext String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user     User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessions WorkbenchSession[]
  items    ProjectItem[]

  @@index([userId])
  @@index([updatedAt])
}

model ProjectItem {
  id        String          @id @default(cuid())
  projectId String
  userId    String
  kind      ProjectItemKind
  sessionId String
  resultId  String?
  title     String
  note      String?
  createdAt DateTime        @default(now())

  project Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  session WorkbenchSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  result  Result?          @relation(fields: [resultId], references: [id], onDelete: Cascade)

  @@index([projectId, createdAt])
  @@index([userId])
  @@index([sessionId])
  @@index([resultId])
}

model WorkbenchSession {
  id                        String   @id @default(cuid())
  userId                    String
  projectId                 String?
  title                     String
  originalInput             String
  originalInputCiphertext   String?
  originalInputIv           String?
  originalInputTag          String?
  additionalInstruction     String?
  outputStyle               String?
  outputLanguage            String?
  workflowControlJson       String?
  workflowTemplateStepsJson String?
  mode                      String
  finalResultId             String?
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  user                   User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  project                Project?                @relation(fields: [projectId], references: [id], onDelete: SetNull)
  workflowSteps          WorkflowStep[]
  results                Result[]
  executionRuns          ExecutionRun[]
  executionRunSteps      ExecutionRunStep[]
  aiRequests             AiRequest[]
  adminContentAccessLogs AdminContentAccessLog[]
  attachments            SessionAttachment[]
  sharedLink             SharedLink?
  parallelComparisons    ParallelComparison[]
  projectItems           ProjectItem[]

  @@index([userId])
  @@index([projectId])
  @@index([updatedAt])
}

model ExecutionRun {
  id                   String    @id @default(cuid())
  userId               String
  sessionId            String?
  workflowRunId        String?   @unique
  runnerVersion        String    @default("v1")
  parentExecutionRunId String?
  branchFromOrderIndex Int?
  branchReason         String?
  mode                 String
  requestType          String
  status               String
  inputCharCount       Int       @default(0)
  totalStepsPlanned    Int       @default(0)
  totalStepsDone       Int       @default(0)
  finalResultId        String?
  errorMessage         String?
  streamError          String?
  executionSummaryJson String?
  stepControlJson      String?
  usageReservationId   String?
  startedAt            DateTime?
  finishedAt           DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  user               User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  session            WorkbenchSession?  @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  parentExecutionRun ExecutionRun?      @relation("ExecutionRunBranch", fields: [parentExecutionRunId], references: [id], onDelete: SetNull)
  childExecutionRuns ExecutionRun[]     @relation("ExecutionRunBranch")
  results            Result[]
  steps              ExecutionRunStep[]

  @@index([userId, status])
  @@index([sessionId])
  @@index([createdAt])
}

model ExecutionRunStep {
  id                  String    @id @default(cuid())
  executionRunId      String
  sessionId           String
  orderIndex          Int
  stepKey             String    @unique
  attemptKey          String?
  templateStepIndex   Int
  templateStepId      String?
  actionType          String
  targetProvider      String
  targetModel         String
  sourceMode          String
  sourceResultId      String?
  instructionTemplate String?
  repeatBlockIndex    Int?
  repeatIteration     Int?
  repeatRangeStart    Int?
  repeatRangeEnd      Int?
  status              String    @default("queued")
  attemptCount        Int       @default(0)
  maxAttempts         Int       @default(3)
  queuedAt            DateTime?
  nextAttemptAt       DateTime?
  startedAt           DateTime?
  completedAt         DateTime?
  failedAt            DateTime?
  canceledAt          DateTime?
  lockedBy            String?
  lockExpiresAt       DateTime?
  heartbeatAt         DateTime?
  sourceTextSnapshot  String?
  promptSnapshot      String?
  promptHash          String?
  resultId            String?   @unique
  errorCode           String?
  errorMessage        String?
  errorRetryable      Boolean   @default(false)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  executionRun ExecutionRun     @relation(fields: [executionRunId], references: [id], onDelete: Cascade)
  session      WorkbenchSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  result       Result?          @relation("ExecutionRunStepResult", fields: [resultId], references: [id])

  @@unique([executionRunId, orderIndex])
  @@index([executionRunId, status])
  @@index([sessionId, executionRunId])
  @@index([status, nextAttemptAt])
  @@index([status, lockExpiresAt])
}

model WorkflowStep {
  id                  String   @id @default(cuid())
  sessionId           String
  orderIndex          Int
  actionType          String
  targetProvider      String
  targetModel         String
  sourceMode          String
  sourceResultId      String?
  instructionTemplate String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  session WorkbenchSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  results Result[]

  @@index([sessionId])
  @@index([sourceResultId])
}

model SharedLink {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  sessionId String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  session WorkbenchSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

model ParallelComparison {
  id                String   @id @default(cuid())
  sessionId         String
  signature         String
  summary           String
  provider          String
  model             String
  comparedResultIds String[]
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  session WorkbenchSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, signature])
  @@index([sessionId])
}

model Result {
  id                   String   @id @default(cuid())
  sessionId            String
  executionRunId       String?
  executionOrder       Int?
  workflowStepId       String?
  parentResultId       String?
  branchKey            String?
  provider             String
  model                String
  promptSnapshot       String
  outputText           String?
  outputTextCiphertext String?
  outputTextIv         String?
  outputTextTag        String?
  rawResponse          String?
  status               String
  errorMessage         String?
  tokenUsagePrompt     Int?
  tokenUsageCompletion Int?
  estimatedCost        Float?
  costIsEstimated      Boolean  @default(false)
  latencyMs            Int?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  session          WorkbenchSession   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  executionRun     ExecutionRun?      @relation(fields: [executionRunId], references: [id], onDelete: SetNull)
  executionRunStep ExecutionRunStep?  @relation("ExecutionRunStepResult")
  workflowStep     WorkflowStep?      @relation(fields: [workflowStepId], references: [id], onDelete: SetNull)
  parent           Result?            @relation("ResultBranches", fields: [parentResultId], references: [id], onDelete: SetNull)
  children         Result[]           @relation("ResultBranches")
  aiRequests       AiRequest[]        @relation("ResultAiRequests")
  attachmentLinks  ResultAttachment[]
  projectItems     ProjectItem[]

  @@unique([executionRunId, executionOrder])
  @@index([sessionId])
  @@index([executionRunId])
  @@index([workflowStepId])
  @@index([parentResultId])
}

model SessionAttachment {
  id            String         @id @default(cuid())
  userId        String
  sessionId     String?
  name          String
  mimeType      String
  kind          AttachmentKind
  sizeBytes     Int
  storagePath   String
  extractedText String?
  dataBase64    String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  session     WorkbenchSession?  @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  resultLinks ResultAttachment[]

  @@index([userId])
  @@index([sessionId])
  @@index([createdAt])
}

model ResultAttachment {
  resultId     String
  attachmentId String
  createdAt    DateTime @default(now())

  result     Result            @relation(fields: [resultId], references: [id], onDelete: Cascade)
  attachment SessionAttachment @relation(fields: [attachmentId], references: [id], onDelete: Cascade)

  @@id([resultId, attachmentId])
  @@index([attachmentId])
}

model AiRequest {
  id               String   @id @default(cuid())
  userId           String   @map("user_id")
  conversationId   String?  @map("conversation_id")
  messageId        String?  @map("message_id")
  provider         String
  model            String
  requestType      String   @map("request_type")
  status           String
  inputTokens      Int?     @map("input_tokens")
  outputTokens     Int?     @map("output_tokens")
  estimatedCostUsd Float?   @map("estimated_cost_usd")
  latencyMs        Int?     @map("latency_ms")
  errorCode        String?  @map("error_code")
  errorMessage     String?  @map("error_message")
  createdAt        DateTime @default(now()) @map("created_at")

  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversation WorkbenchSession? @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  message      Result?           @relation("ResultAiRequests", fields: [messageId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([conversationId])
  @@index([messageId])
  @@index([provider, model])
  @@index([status, createdAt])
  @@map("ai_requests")
}

model TrialAccess {
  id                String    @id @default(cuid())
  ipHash            String    @unique
  trialUserId       String    @unique
  conversationCount Int       @default(0)
  startedAt         DateTime  @default(now())
  lastUsedAt        DateTime?
  limitReachedAt    DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  trialUser User @relation(fields: [trialUserId], references: [id], onDelete: Cascade)

  @@index([startedAt])
}

model Preset {
  id           String   @id @default(cuid())
  userId       String
  name         String
  description  String?
  workflowJson String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model AdminSession {
  id            String    @id @default(cuid())
  userId        String
  tokenHash     String    @unique
  expiresAt     DateTime
  mfaVerifiedAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user User @relation("AdminSessions", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model AdminAuditLog {
  id          String           @id @default(cuid())
  adminUserId String?
  action      AdminAuditAction
  targetType  String?
  targetId    String?
  detailJson  String?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime         @default(now())

  adminUser User? @relation("AdminAuditBy", fields: [adminUserId], references: [id], onDelete: SetNull)

  @@index([adminUserId])
  @@index([action])
  @@index([createdAt])
}

model AdminContentAccessLog {
  id               String   @id @default(cuid())
  adminUserId      String
  viewedUserId     String
  conversationId   String
  accessReasonCode String
  createdAt        DateTime @default(now())

  adminUser    User             @relation("AdminContentAccessBy", fields: [adminUserId], references: [id], onDelete: Cascade)
  viewedUser   User             @relation("AdminContentAccessViewed", fields: [viewedUserId], references: [id], onDelete: Cascade)
  conversation WorkbenchSession @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([adminUserId])
  @@index([viewedUserId])
  @@index([conversationId])
  @@index([createdAt])
}

model Coupon {
  id               String     @id @default(cuid())
  code             String     @unique
  type             CouponType
  creditAmount     Int?
  isActive         Boolean    @default(true)
  createdByAdminId String
  redeemedByUserId String?
  redeemedAt       DateTime?
  note             String?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  createdByAdmin     User                 @relation("CouponCreatedBy", fields: [createdByAdminId], references: [id], onDelete: Restrict)
  redeemedByUser     User?                @relation("CouponRedeemedBy", fields: [redeemedByUserId], references: [id], onDelete: SetNull)
  redemptions        CouponRedemption[]
  subscriptionLedger SubscriptionLedger[]

  @@index([type, isActive])
  @@index([redeemedAt])
}

model CouponRedemption {
  id              String                 @id @default(cuid())
  couponId        String
  userId          String
  result          CouponRedemptionResult
  note            String?
  grantStartAt    DateTime?
  grantEndAt      DateTime?
  grantIsLifetime Boolean                @default(false)
  creditAmount    Int?
  creditExpiresAt DateTime?
  createdAt       DateTime               @default(now())

  coupon Coupon @relation(fields: [couponId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([couponId])
  @@index([userId])
  @@index([createdAt])
}

model UserSubscription {
  id                    String    @id @default(cuid())
  userId                String    @unique
  planEndsAt            DateTime?
  isLifetime            Boolean   @default(false)
  couponDailyLimit      Int?
  couponLimitEndsAt     DateTime?
  couponLimitIsLifetime Boolean   @default(false)
  couponCreditBalance   Int       @default(0)
  couponCreditEndsAt    DateTime?
  // Active "unlimited credits" coupon grant expiry. While in the future, the
  // user's credit ceilings are lifted for the period.
  couponUnlimitedUntil  DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UsageLimit {
  id                String   @id @default(cuid())
  userId            String
  usageDate         DateTime @db.Date
  dailyRequestLimit Int      @default(10)
  dailyRequestUsed  Int      @default(0)
  bonusRequestLimit Int      @default(0)
  resetAt           DateTime
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  reservations UsageReservation[]

  @@unique([userId, usageDate])
  @@index([userId, usageDate])
  @@index([resetAt])
}

model UsageReservation {
  id                   String    @id @default(cuid())
  reservationKey       String    @unique
  userId               String
  usageLimitId         String
  requestType          String
  reservedRequestCount Int       @default(1)
  reservedCreditCount  Int       @default(0)
  settledCreditCount   Int       @default(0)
  estimatedCostUsd     Decimal   @default(0) @db.Decimal(10, 6)
  maxApprovedCredits   Int       @default(0)
  pricingVersion       String?
  quoteJson            String?
  inputCharCount       Int       @default(0)
  status               String    @default("reserved")
  expiresAt            DateTime
  settledAt            DateTime?
  releasedAt           DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  usageLimit UsageLimit @relation(fields: [usageLimitId], references: [id], onDelete: Cascade)

  @@index([userId, status, createdAt])
  @@index([usageLimitId, status])
  @@index([expiresAt])
}

model UsageLog {
  id                  String      @id @default(cuid())
  userId              String
  requestType         String
  selectedModels      String[]
  planTypeSnapshot    PlanType
  billingTypeSnapshot BillingType
  isBoostSnapshot     Boolean     @default(false)
  inputCharCount      Int         @default(0)
  inputTokenCount     Int         @default(0)
  outputTokenCount    Int         @default(0)
  requestCountCharged Int         @default(1)
  estimatedCostUsd    Decimal     @default(0) @db.Decimal(10, 6)
  creditsUsed         Int         @default(0)
  createdAt           DateTime    @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([requestType, createdAt])
  @@index([planTypeSnapshot, createdAt])
  @@index([isBoostSnapshot, createdAt])
}

model ProviderLease {
  id           String    @id @default(cuid())
  providerName String
  leaseKey     String    @unique
  ownerKind    String
  ownerId      String
  model        String?
  expiresAt    DateTime
  releasedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([providerName, releasedAt, expiresAt])
  @@index([ownerKind, ownerId])
  @@index([expiresAt])
}

model CreditWallet {
  id               String   @id @default(cuid())
  userId           String   @unique
  paidCredits      Int      @default(0)
  bonusCredits     Int      @default(0)
  totalUsedCredits Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PaymentPlan {
  id                 String   @id @default(cuid())
  name               String
  planType           PlanType
  billingCycle       String
  priceKrw           Int
  dailyRequestLimit  Int?
  monthlyCreditLimit Int?
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())

  @@index([planType, isActive])
}

model SubscriptionLedger {
  id               String                @id @default(cuid())
  userId           String
  couponId         String?
  grantedByAdminId String?
  eventType        SubscriptionEventType
  subscriptionType SubscriptionType
  startAt          DateTime
  endAt            DateTime?
  isLifetime       Boolean               @default(false)
  note             String?
  createdAt        DateTime              @default(now())

  user           User    @relation("SubscriptionLedgerUser", fields: [userId], references: [id], onDelete: Cascade)
  coupon         Coupon? @relation(fields: [couponId], references: [id], onDelete: SetNull)
  grantedByAdmin User?   @relation("SubscriptionGrantedByAdmin", fields: [grantedByAdminId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
}

model AdminProviderConfig {
  id                  String    @id @default(cuid())
  providerName        String    @unique
  defaultModel        String
  isEnabled           Boolean   @default(false)
  fallbackProvider    String?
  perUserDailyLimit   Int       @default(100)
  timeoutSeconds      Int       @default(60)
  healthStatus        String    @default("unknown")
  lastHealthCheckedAt DateTime?
  apiKeyCiphertext    String?
  apiKeyIv            String?
  apiKeyTag           String?
  apiKeyMasked        String?
  updatedByAdminId    String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  updatedByAdmin User? @relation("AdminProviderUpdatedBy", fields: [updatedByAdminId], references: [id], onDelete: SetNull)
}

model AdminSystemSetting {
  id               String   @id @default(cuid())
  settingKey       String   @unique
  valueJson        String
  updatedByAdminId String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  updatedByAdmin User? @relation("SystemSettingUpdatedBy", fields: [updatedByAdminId], references: [id], onDelete: SetNull)
}

model FeedbackPost {
  id          String           @id @default(cuid())
  userId      String
  title       String
  body        String
  category    FeedbackCategory @default(OTHER)
  status      FeedbackStatus   @default(OPEN)
  adminUnread Boolean          @default(true)
  userUnread  Boolean          @default(false)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  user        User                 @relation("FeedbackAuthor", fields: [userId], references: [id], onDelete: Cascade)
  comments    FeedbackComment[]
  attachments FeedbackAttachment[]

  @@index([userId, createdAt])
  @@index([status, createdAt])
  @@index([createdAt])
}

model FeedbackComment {
  id        String   @id @default(cuid())
  postId    String
  authorId  String
  isAdmin   Boolean  @default(false)
  body      String
  createdAt DateTime @default(now())

  post   FeedbackPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  author User         @relation("FeedbackCommentAuthor", fields: [authorId], references: [id], onDelete: Cascade)

  @@index([postId, createdAt])
  @@index([authorId])
}

model FeedbackAttachment {
  id          String   @id @default(cuid())
  userId      String
  postId      String?
  name        String
  mimeType    String
  sizeBytes   Int
  storagePath String
  dataBase64  String?
  createdAt   DateTime @default(now())

  user User          @relation("FeedbackAttachmentOwner", fields: [userId], references: [id], onDelete: Cascade)
  post FeedbackPost? @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([postId])
}
