DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/DBNAME?sslmode=require&pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require"
# Legacy runtime fallback used only when DATABASE_URL is empty or invalid.
POSTGRES_PRISMA_URL=""
APP_BASE_URL="https://yapp.wideget.net"
CANONICAL_APP_URL="https://yapp.wideget.net"
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
QSTASH_TOKEN=""
QSTASH_CURRENT_SIGNING_KEY=""
QSTASH_NEXT_SIGNING_KEY=""
INTERNAL_WORKER_SECRET=""
UPSTASH_REDIS_REST_URL="https://YOUR-DATABASE.upstash.io"
UPSTASH_REDIS_REST_TOKEN=""
# Generate with: openssl rand -base64 48 (store only in the deployment secret store).
APP_SECRET=""
DB_ENCRYPTION_KEY=""
TRIAL_CONVERSATION_LIMIT="5"
TRIAL_SESSION_HOURS="24"
FREE_USER_DAILY_TOKEN_LIMIT="50000"

# Optional server-side provider keys.
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
GOOGLE_API_KEY=""
XAI_API_KEY=""

# Google OAuth (automatic sign-up/sign-in)
GOOGLE_OAUTH_CLIENT_ID=""
GOOGLE_OAUTH_CLIENT_SECRET=""
GOOGLE_OAUTH_REDIRECT_URI="https://yapp.wideget.net/api/auth/google/callback"

# Admins are promoted only through the offline launch runbook. Static MFA codes
# and INITIAL_ADMIN_EMAILS are intentionally unsupported.
ADMIN_TOTP_SECRET=""
