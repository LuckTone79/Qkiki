DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/DBNAME?sslmode=require&pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require"
# Legacy runtime fallback used only when DATABASE_URL is empty or invalid.
POSTGRES_PRISMA_URL=""
APP_BASE_URL="https://yapp.wideget.net"
CANONICAL_APP_URL="https://yapp.wideget.net"
QSTASH_TOKEN=""
QSTASH_CURRENT_SIGNING_KEY=""
QSTASH_NEXT_SIGNING_KEY=""
INTERNAL_WORKER_SECRET=""
APP_SECRET="replace-with-a-long-random-secret"
DB_ENCRYPTION_KEY="replace-with-a-different-long-random-secret"
TRIAL_CONVERSATION_LIMIT="5"
TRIAL_SESSION_HOURS="24"
FREE_USER_DAILY_TOKEN_LIMIT="50000"

# Optional server-side provider keys.
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
GOOGLE_API_KEY=""
XAI_API_KEY=""

# Supabase Auth. Project URL/keys: Supabase Dashboard > Project Settings > API.
# See docs/AUTH_SETUP.md for the full setup checklist (OAuth providers,
# Turnstile CAPTCHA, SMTP, rate limits).
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT-REF.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
# Service role key. Server-only — never expose to the client. Used to link
# legacy accounts and bypass RLS for trusted server-side operations.
SUPABASE_SERVICE_ROLE_KEY=""

# Cloudflare Turnstile (bot protection on sign-up/sign-in/password reset).
# Site key is public; the secret key is configured in the Supabase Dashboard
# under Authentication > Attack Protection, not here.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""

# Bootstrap admin settings. Admin access is now role-gated through Supabase
# Auth (see docs/AUTH_SETUP.md) — GOOGLE_OAUTH_* and ADMIN_MFA_CODE are no
# longer read by the app and can be removed from your deploy environment.
INITIAL_ADMIN_EMAILS="admin@example.com"
