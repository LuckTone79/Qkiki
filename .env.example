DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/DBNAME?sslmode=require&pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require"
# Legacy runtime fallback used only when DATABASE_URL is empty or invalid.
POSTGRES_PRISMA_URL=""
APP_BASE_URL="https://yapp.wideget.net"
CANONICAL_APP_URL="https://yapp.wideget.net"
QSTASH_TOKEN=""
QSTASH_CURRENT_SIGNING_KEY=""
QSTASH_NEXT_SIGNING_KEY=""
INTERNAL_WORKER_SECRET=""
APP_SECRET="replace-with-a-long-random-secret"
DB_ENCRYPTION_KEY="replace-with-a-different-long-random-secret"
TRIAL_CONVERSATION_LIMIT="5"
TRIAL_SESSION_HOURS="24"
FREE_USER_DAILY_TOKEN_LIMIT="50000"

# Emergency-only fallback. Production normally relies on migrations plus the
# workbench schema assertion in scripts/prebuild-migrate.mjs.
LEGACY_WORKBENCH_SCHEMA_REPAIR="0"
# Opt-in response timing diagnostics. Keep disabled during normal operation.
PERF_TRACE="0"

# Optional server-side provider keys.
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
GOOGLE_API_KEY=""
XAI_API_KEY=""

# Google OAuth (automatic sign-up/sign-in)
GOOGLE_OAUTH_CLIENT_ID=""
GOOGLE_OAUTH_CLIENT_SECRET=""
# Optional. If blank, defaults to {origin}/api/auth/google/callback
GOOGLE_OAUTH_REDIRECT_URI=""

# Bootstrap and admin security settings
INITIAL_ADMIN_EMAILS="admin@example.com"
# Required for admin sign-in. Use a private, rotated operational code.
ADMIN_MFA_CODE="change-me"
